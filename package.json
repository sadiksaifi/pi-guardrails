{
  "name": "pi-guardrails",
  "private": true,
  "keywords": [
    "pi-package"
  ],
  "type": "module",
  "module": "src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "fmt:check": "oxfmt --check .",
    "fmt:fix": "oxfmt .",
    "lint": "oxlint . --report-unused-disable-directives",
    "test": "bun test"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.68.0",
    "@types/bun": "^1.3.12",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  }
}
