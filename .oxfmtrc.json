{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": ["bun.lock", "coverage/**", "dist/**", "node_modules/**", "out/**"],
  "endOfLine": "lf",
  "insertFinalNewline": true,
  "printWidth": 100,
  "quoteProps": "as-needed",
  "semi": true,
  "singleQuote": false,
  "jsxSingleQuote": false,
  "tabWidth": 2,
  "trailingComma": "all",
  "useTabs": false
}
